{
    "name": "shopware-data-generator",
    "version": "2.0.0",
    "private": true,
    "description": "A tool to create AI-generated demo data for Shopware",
    "author": "Philipp Schuch",
    "files": [
        "dist"
    ],
    "type": "module",
    "main": "dist/main.js",
    "scripts": {
        "build": "bun run lint && bun run format && bun build ./src/main.ts --outdir=dist --target=bun",
        "dev": "bun run --watch src/main.ts",
        "typecheck": "tsc --noEmit",
        "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
        "typecheck:all": "bun run typecheck && bun run typecheck:tests",
        "lint": "oxlint --fix && bun run typecheck:all && bun run lint:dead && bun run lint:no-cast",
        "lint:no-cast": "bun run scripts/lint-no-cast.ts",
        "lint:dead": "knip",
        "format": "npx oxfmt --write .",
        "check-format": "npx oxfmt --check .",
        "blueprint": "bun run src/main.ts blueprint",
        "generate": "bun run src/main.ts generate",
        "process": "bun run src/main.ts process",
        "server": "bun run src/server.ts",
        "cache:list": "bun run src/cache-cli.ts list",
        "cache:clear": "bun run src/cache-cli.ts clear",
        "cache:trash": "bun run src/cache-cli.ts trash",
        "cache:restore": "bun run src/cache-cli.ts restore",
        "cache:empty-trash": "bun run src/cache-cli.ts empty-trash",
        "logs:clear": "rm -rf logs/",
        "cleanup": "bun run src/cleanup-cli.ts",
        "cleanup:props": "bun run src/cleanup-cli.ts --all-props",
        "cleanup:media": "bun run src/cleanup-cli.ts --orphaned-media",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "test:coverage": "bun test --coverage",
        "test:e2e": "./test-e2e.sh",
        "test:verify": "bun run tests/e2e/verify.ts",
        "migrate:variants": "bun run src/migrate-variants.ts",
        "mcp": "bun run src/mcp/index.ts",
        "mcp:dev": "npx fastmcp dev src/mcp/index.ts",
        "mcp:inspect": "npx fastmcp inspect src/mcp/index.ts"
    },
    "dependencies": {
        "@shopware/api-client": "^1.5.0",
        "openai": "^6.33.0",
        "sharp": "^0.34.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "@wong2/mcp-cli": "^1.13.0",
        "fastmcp": "^3.34.0",
        "knip": "^6.1.1",
        "oxfmt": "^0.43.0",
        "oxlint": "^1.58.0",
        "typescript": "^6.0.2"
    }
}
