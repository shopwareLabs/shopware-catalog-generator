# =============================================================================
# AI Data Generator - Environment Configuration
# =============================================================================
# Copy this file to .env and configure your settings.

# =============================================================================
# Shopware Configuration (for CLI usage)
# =============================================================================

# Shopware environment URL
SW_ENV_URL=http://localhost:8000

# API client credentials (Integration -> Access key)
# If not provided, falls back to admin:shopware dev credentials
SW_CLIENT_ID=
SW_CLIENT_SECRET=

# =============================================================================
# Cache Configuration (Optional)
# =============================================================================

# Enable/disable caching of generated products and images
# Default: true
CACHE_ENABLED=true

# Directory for cached data
# Default: ./generated
CACHE_DIR=./generated

# =============================================================================
# Server Configuration (for server mode)
# =============================================================================

# Port for the HTTP server
# Default: 3000
SERVER_PORT=3000

# =============================================================================
# AI Provider Configuration
# =============================================================================

# AI provider for text generation: openai | github-models | pollinations
# Default: pollinations
AI_PROVIDER=pollinations

# API key for the AI provider (required)
# - Pollinations: Get key at https://enter.pollinations.ai (sk_ for parallel, pk_ for sequential)
# - OpenAI: sk-your-openai-key-here
# - GitHub Models: ghp_your_github_pat_here
AI_API_KEY=

# Optional: Override the default text model
# - OpenAI default: gpt-4.1-2025-04-14
# - GitHub Models default: gpt-4o
# - Pollinations default: openai
AI_MODEL=

# =============================================================================
# Image Provider Configuration (Optional)
# =============================================================================

# Image provider: openai | pollinations | none
# Default: Automatically inferred from AI_PROVIDER
# - openai -> openai (DALL-E gpt-image-1)
# - github-models -> pollinations
# - pollinations -> pollinations
IMAGE_PROVIDER=

# Separate API key for image provider (if different from AI_API_KEY)
IMAGE_API_KEY=

# Override image model (see README for pricing details)
# OpenAI: gpt-image-1.5 (default), gpt-image-1 | Pollinations: flux (default), klein, turbo
IMAGE_MODEL=
